<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Llaveros - D3DSLAYER</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --naranja: #F26522;
            --naranja-oscuro: #D35400;
            --verde: #2ECC71;
            --negro: #0D0D0D;
            --gris-oscuro: #1A1A1A;
            --gris-medio: #2A2A2A;
            --blanco: #FFFFFF;
            --gris-texto: #B0B0B0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--negro);
            color: var(--blanco);
        }

        /* NAVBAR */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 5%;
            background: rgba(13, 13, 13, 0.95);
            backdrop-filter: blur(10px);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(242, 101, 34, 0.2);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .logo img {
            height: 55px;
            width: auto;
            object-fit: cover;
            filter: drop-shadow(0 0 10px rgba(242, 101, 34, 0.6));
        }

        .logo-text {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--naranja);
            letter-spacing: 2px;
        }

        .back-btn {
            color: var(--blanco);
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color 0.3s;
        }

        .back-btn:hover { color: var(--naranja); }

        /* HEADER */
        .page-header {
            padding: 120px 5% 40px;
            text-align: center;
        }

        .page-header h1 {
            font-size: 3rem;
            font-weight: 900;
            color: var(--naranja);
            margin-bottom: 10px;
        }

        .page-header p {
            color: var(--gris-texto);
            font-size: 1.1rem;
        }

        /* PRODUCTOS GRID */
        .productos-page {
            padding: 40px 5% 80px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .producto-item {
            background: var(--gris-medio);
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid rgba(242, 101, 34, 0.1);
            transition: all 0.3s;
        }

        .producto-item:hover {
            transform: translateY(-10px);
            border-color: var(--naranja);
            box-shadow: 0 20px 40px rgba(242, 101, 34, 0.2);
        }

        /* ===== GALERÍA DE FOTOS ===== */
        .galeria {
            position: relative;
            width: 100%;
            height: 280px;
            overflow: hidden;
            background: var(--gris-oscuro);
            cursor: zoom-in;
        }

        .galeria-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: none;
            padding: 10px;
        }

        .galeria-img.active {
            display: block;
        }

        /* Flechas de navegación */
        .galeria-flecha {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(0,0,0,0.6);
            color: var(--blanco);
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            font-size: 1.2rem;
            cursor: pointer;
            z-index: 10;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .galeria-flecha:hover {
            background: var(--naranja);
        }

        .galeria-flecha.prev { left: 10px; }
        .galeria-flecha.next { right: 10px; }

        /* Indicadores (puntos) */
        .galeria-dots {
            position: absolute;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 8px;
            z-index: 10;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(255,255,255,0.4);
            cursor: pointer;
            transition: all 0.3s;
        }

        .dot.active {
            background: var(--naranja);
            width: 25px;
            border-radius: 5px;
        }

        /* Contador de fotos */
        .galeria-contador {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.6);
            color: var(--blanco);
            padding: 5px 12px;
            border-radius: 15px;
            font-size: 0.8rem;
            font-weight: 600;
            z-index: 10;
        }

        .producto-item-info {
            padding: 20px;
        }

        .producto-item-info h3 {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .producto-item-info .precio {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--naranja);
            margin-bottom: 10px;
        }

        .producto-item-info p {
            color: var(--gris-texto);
            font-size: 0.9rem;
            margin-bottom: 15px;
            line-height: 1.5;
        }

        .pedir-btn {
            display: block;
            background: var(--verde);
            color: var(--blanco);
            padding: 14px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 800;
            text-align: center;
            text-transform: uppercase;
            transition: all 0.3s;
        }

        .pedir-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 30px rgba(46, 204, 113, 0.3);
        }

        /* ===== MODAL ZOOM ===== */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }

        .modal.active {
            display: flex;
        }

        .modal-img {
            max-width: 90%;
            max-height: 80vh;
            object-fit: contain;
            border-radius: 10px;
        }

        .modal-cerrar {
            position: absolute;
            top: 20px;
            right: 30px;
            color: var(--blanco);
            font-size: 2.5rem;
            cursor: pointer;
            background: none;
            border: none;
            transition: color 0.3s;
        }

        .modal-cerrar:hover {
            color: var(--naranja);
        }

        .modal-nav {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }

        .modal-nav button {
            background: var(--naranja);
            color: var(--blanco);
            border: none;
            padding: 10px 25px;
            border-radius: 25px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
        }

        .modal-nav button:hover {
            background: var(--naranja-oscuro);
            transform: scale(1.05);
        }

        .modal-contador {
            color: var(--gris-texto);
            margin-top: 10px;
            font-size: 0.9rem;
        }

        /* FOOTER */
        .footer-simple {
            text-align: center;
            padding: 30px;
            color: var(--gris-texto);
            border-top: 1px solid rgba(242, 101, 34, 0.2);
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .productos-page {
                grid-template-columns: 1fr;
                padding: 20px 3% 60px;
            }

            .page-header h1 {
                font-size: 2rem;
            }

            .galeria {
                height: 250px;
            }
        }
    </style>
