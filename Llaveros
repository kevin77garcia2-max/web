    <script>
        // Estado de cada producto (qué imagen está activa)
        const estados = [0, 0, 0, 0, 0, 0];
        
        const imagenes = [
            ['llavero1-1.jpg', 'llavero1-2.jpg', 'llavero1-3.jpg', 'llavero1-4.jpg'],
            ['llavero2-1.jpg', 'llavero2-2.jpg', 'llavero2-3.jpg', 'llavero2-4.jpg'],
            ['llavero3-1.jpg', 'llavero3-2.jpg', 'llavero3-3.jpg', 'llavero3-4.jpg'],
            ['llavero4-1.jpg', 'llavero4-2.jpg', 'llavero4-3.jpg', 'llavero4-4.jpg'],
            ['llavero5-1.jpg', 'llavero5-2.jpg', 'llavero5-3.jpg', 'llavero5-4.jpg'],
            ['llavero6-1.jpg', 'llavero6-2.jpg', 'llavero6-3.jpg', 'llavero6-4.jpg']
        ];

        let modalProd = 0;
        let modalImg = 0;

        function cambiarImg(prod, direccion) {
            const imgs = document.querySelectorAll(`.galeria-img[data-prod="${prod}"]`);
            const dots = document.querySelectorAll(`.producto-item:nth-child(${prod + 1}) .dot`);
            const contador = document.querySelector(`.producto-item:nth-child(${prod + 1}) .galeria-contador`);

            imgs[estados[prod]].classList.remove('active');
            dots[estados[prod]].classList.remove('active');

            estados[prod] += direccion;
            if (estados[prod] >= imgs.length) estados[prod] = 0;
            if (estados[prod] < 0) estados[prod] = imgs.length - 1;

            imgs[estados[prod]].classList.add('active');
            dots[estados[prod]].classList.add('active');
            contador.textContent = `${estados[prod] + 1} / ${imgs.length}`;
        }

        function irAImg(prod, img) {
            const imgs = document.querySelectorAll(`.galeria-img[data-prod="${prod}"]`);
            const dots = document.querySelectorAll(`.producto-item:nth-child(${prod + 1}) .dot`);
            const contador = document.querySelector(`.producto-item:nth-child(${prod + 1}) .galeria-contador`);

            imgs[estados[prod]].classList.remove('active');
            dots[estados[prod]].classList.remove('active');

            estados[prod] = img;

            imgs[estados[prod]].classList.add('active');
            dots[estados[prod]].classList.add('active');
            contador.textContent = `${estados[prod] + 1} / ${imgs.length}`;
        }

        function abrirModal(prod) {
            modalProd = prod;
            modalImg = estados[prod];
            actualizarModal();
            document.getElementById('modal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function cerrarModal(e) {
            if (e.target.id === 'modal' || e.target.classList.contains('modal-cerrar')) {
                document.getElementById('modal').classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        }

        function modalCambiar(dir) {
            modalImg += dir;
            if (modalImg >= imagenes[modalProd].length) modalImg = 0;
            if (modalImg < 0) modalImg = imagenes[modalProd].length - 1;
            actualizarModal();
        }

        function actualizarModal() {
            document.getElementById('modal-img').src = imagenes[modalProd][modalImg];
            document.getElementById('modal-contador').textContent = `${modalImg + 1} / ${imagenes[modalProd].length}`;
        }
    </script>

